rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwnerOrManager() {
      // Guard: user doc must exist before calling userRole() to avoid errors
      return isLoggedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userRole() in ["owner", "manager"];
    }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {

      // Read own doc
      allow get: if isLoggedIn() && request.auth.uid == userId;

      // Owner/Manager can read any doc or list all
      allow get, list: if isOwnerOrManager();

      // Registration: allow create if the uid in the doc matches the requester
      // This covers both normal registration and the ensureUserProfile() fallback
      allow create: if isLoggedIn() && request.auth.uid == userId;

      // Update own profile (cannot self-promote role) OR owner/manager can change role
      allow update: if isLoggedIn() && (
                      (request.auth.uid == userId &&
                       !("role" in request.resource.data.diff(resource.data).affectedKeys()))
                      || isOwnerOrManager()
                    );

      allow delete: if isOwnerOrManager();
    }

    // ── menuItems ─────────────────────────────────────────────────────────────
    match /menuItems/{itemId} {
      allow read:   if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isLoggedIn();
    }

    // ── orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if false;
    }
  }
}
