rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwnerOrManager() {
      return isLoggedIn() && userRole() in ["owner", "manager"];
    }

    function isCashier() {
      return isLoggedIn() && userRole() in ["owner", "manager", "cashier"];
    }

    function isKitchen() {
      return isLoggedIn() && userRole() in ["owner", "manager", "kitchen", "staff"];
    }

    function isDelivery() {
      return isLoggedIn() && userRole() in ["delivery"];
    }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get:    if isLoggedIn() && (request.auth.uid == userId || isOwnerOrManager());
      allow list:   if isOwnerOrManager();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
                      (request.auth.uid == userId &&
                       !("role" in request.resource.data.diff(resource.data).affectedKeys()))
                      || isOwnerOrManager()
                    );
      allow delete: if isOwnerOrManager();
    }

    // ── menuItems ─────────────────────────────────────────────────────────────
    match /menuItems/{itemId} {
      allow read:   if true;   // Anyone can browse menu
      allow create: if isOwnerOrManager();
      allow update: if isOwnerOrManager();
      allow delete: if isOwnerOrManager();
    }

    // ── orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Customer can read their own orders; staff can read all
      allow read:   if isLoggedIn() && (
                      resource.data.userId == request.auth.uid
                      || isOwnerOrManager()
                      || isCashier()
                      || isKitchen()
                      || isDelivery()
                    );
      allow create: if isLoggedIn();   // Any logged-in user can place order
      allow update: if isLoggedIn() && (
                      // Customer can only update their own (e.g. cancel)
                      (resource.data.userId == request.auth.uid)
                      || isOwnerOrManager()
                      || isCashier()
                      || isKitchen()
                      || isDelivery()
                    );
      allow delete: if false;
    }

    // ── riderRegistrations ────────────────────────────────────────────────────
    match /riderRegistrations/{regId} {
      allow read:   if isLoggedIn() && (
                      resource.data.uid == request.auth.uid
                      || isOwnerOrManager()
                    );
      allow create: if isLoggedIn();
      allow update: if isOwnerOrManager();
      allow delete: if isOwnerOrManager();
    }

  }
}
